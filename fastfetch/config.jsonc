{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/dotfiles/assets/terminal/fastfetch/frieren.JPG",
        "type": "iterm",
        "width": 40,
        "padding": {
            "top": 1
        }
    },
    "modules": [
        "title",
        "separator",
        {
            "type": "custom",
            "format": "\uf0e5 \u001b[1;36m「縦ロールになっちゃった...」\u001b[0m"
        },
        "os",
        "host",
        "kernel",
        "uptime",
        "packages",
        "shell",
        "display",
        "de",
        "wm",
        "terminal",
        "cpu",
        "gpu",
        "memory",
        "break",
        "colors"
    ]
}
